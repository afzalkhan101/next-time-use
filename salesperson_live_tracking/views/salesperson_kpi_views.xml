<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- KPI List View -->
    <record id="view_salesperson_kpi_tree" model="ir.ui.view">
        <field name="name">salesperson.kpi.tree</field>
        <field name="model">salesperson.kpi</field>
        <field name="arch" type="xml">
            <list string="KPI Summary" default_order="kpi_date desc" class="o_list_compact">
                <field name="kpi_date"/>
                <field name="user_id"/>
                <field name="sale_team_id" optional="show"/>
                <field name="planned_visits"/>
                <field name="completed_visits"/>
                <field name="visit_completion_rate" string="Completion %" widget="percentage"/>
                <field name="total_field_display" string="Field Time"/>
                <field name="avg_visit_duration" string="Avg Visit (min)" optional="show"/>
                <field name="checkin_count" string="Check-Ins" optional="show"/>
                <field name="selfie_count" string="Selfies" optional="show"/>
                <field name="deals_closed" optional="show"/>
                <field name="followups_created" optional="show"/>
            </list>
        </field>
    </record>

    <!-- KPI Form View -->
    <record id="view_salesperson_kpi_form" model="ir.ui.view">
        <field name="name">salesperson.kpi.form</field>
        <field name="model">salesperson.kpi</field>
        <field name="arch" type="xml">
            <form string="KPI Summary">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="user_id" readonly="1"/> —
                            <field name="kpi_date" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Visit Coverage">
                            <field name="planned_visits"/>
                            <field name="completed_visits"/>
                            <field name="visit_completion_rate" widget="percentage" string="Completion Rate (%)"/>
                        </group>
                        <group string="Time Efficiency">
                            <field name="total_field_display" string="Total Field Time"/>
                            <field name="avg_visit_duration" string="Avg Visit Duration (min)"/>
                            <field name="checkin_count" string="Total Check-Ins"/>
                            <field name="selfie_count" string="Selfies Captured"/>
                        </group>
                    </group>
                    <group>
                        <group string="Meeting Outcomes">
                            <field name="deals_closed"/>
                            <field name="followups_created"/>
                            <field name="positive_outcomes"/>
                            <field name="neutral_outcomes"/>
                            <field name="negative_outcomes"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- KPI Action -->
    <record id="action_salesperson_kpi" model="ir.actions.act_window">
        <field name="name">KPI Dashboard</field>
        <field name="res_model">salesperson.kpi</field>
        <field name="view_mode">list,form</field>
        <!-- Removed search_view_id -->
        <field name="context">{}</field>
    </record>

    <menuitem id="menu_salesperson_tracking_root"
          name="Salesperson Tracking"
          sequence="10"/>
</odoo>