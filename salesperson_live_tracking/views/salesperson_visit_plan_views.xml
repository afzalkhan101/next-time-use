<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_salesperson_visit_plan_tree" model="ir.ui.view">
        <field name="name">salesperson.visit.plan.tree</field>
        <field name="model">salesperson.visit.plan</field>
        <field name="arch" type="xml">
            <list string="Planned Visits"
                  decoration-success="is_covered"
                  decoration-danger="not is_covered"
                  default_order="visit_date desc, sequence">
                <field name="sequence" widget="handle"/>
                <field name="visit_date"/>
                <field name="user_id" string="SalesPerson"/>
                <field name="sale_team_id" optional="show"/>
                <field name="partner_id" optional="show"/>
            </list>
        </field>
    </record>
    
    <record id="view_salesperson_visit_plan_form" model="ir.ui.view">
        <field name="name">salesperson.visit.plan.form</field>
        <field name="model">salesperson.visit.plan</field>
        <field name="arch" type="xml">
            <form string="Planned Visit">
                <header>
                    <button name="action_submit"
                            string="Submit"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="btn-success"
                            invisible="state != 'submitted'"/>

                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-danger"
                            invisible="state != 'submitted'"/>

                    <button name="action_done"
                            string="Done"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'approved'"/>

                    <button name="action_reset_draft"
                            string="Reset"
                            type="object"
                            invisible="state not in ('rejected', 'done')"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,rejected,done"/>
                </header>

                <sheet>
                    <div>
                        <h1><field name="name" readonly="1"/></h1>
                        <field name="date"/>
                    </div>

                    <group>
                        <group string="General Information">
                            <field name="visit_date"/>
                            <field name="user_id"/>
                            <field name="partner_id"/>
                        </group>
                        <group string="Details">
                            <field name="priority" widget="priority"/>
                            <field name="manager_notes"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Visit Lines">
                            <field name="space_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="visit_date"/>
                                    <field name="partner_id"/>
                                    <field name="from_location"/>
                                    <field name="to_location"/>
                                    <field name="total_cost"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_salesperson_visit_plan" model="ir.actions.act_window">
        <field name="name">Planned Visits</field>
        <field name="res_model">salesperson.visit.plan</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_salesperson_visit_plan_my" model="ir.actions.act_window">
        <field name="name">My Planned Visits</field>
        <field name="res_model">salesperson.visit.plan</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('user_id', '=', uid)]</field>
        <field name="context">{'default_user_id': uid}</field>
    </record>

    <menuitem id="menu_salesperson_tracking_root"
              name="Salesperson Tracking"
              sequence="1"/>

    <menuitem id="menu_salesperson_visit_plan_my"
              name="My Planned Visits"
              parent="menu_salesperson_tracking_root"
              action="action_salesperson_visit_plan_my"
              sequence="8"
              groups="sales_team.group_sale_salesman"/>

    <menuitem id="menu_salesperson_visit_plan"
              name="Planned Visits"
              parent="menu_salesperson_tracking_root"
              action="action_salesperson_visit_plan"
              sequence="9"
              groups="sales_team.group_sale_manager"/>
</odoo>