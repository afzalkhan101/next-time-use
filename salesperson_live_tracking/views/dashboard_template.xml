<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="salesperson_dashboard" name="Salesperson Live Tracking Dashboard">
    <t t-call="web.layout">

      <t t-set="head">
        <link rel="preconnect" href="https://fonts.googleapis.com"/>
        <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&amp;family=DM+Mono:wght@400;500&amp;display=swap" rel="stylesheet"/>
        <link href="/salesperson_live_tracking/static/src/css/style.css" rel="stylesheet"/>
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
        <style>
          :root {
            --bg:#0d0f14;--surface:#13161e;--surface2:#1b1f2b;
            --border:rgba(255,255,255,0.07);--accent:#4f8ef7;--accent2:#6ee7b7;
            --warn:#f59e0b;--danger:#f87171;--text:#e8eaf0;--muted:#6b7280;
            --live:#22c55e;--idle:#f59e0b;--offline:#4b5563;
            --radius:14px;--radius-sm:8px;
          }
          *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
          body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;font-size:14px;min-height:100vh;overflow-x:hidden}
          ::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:var(--bg)}
          ::-webkit-scrollbar-thumb{background:var(--surface2);border-radius:4px}
          .layout{display:flex;min-height:100vh}
          .sidebar{width:64px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;align-items:center;padding:20px 0;gap:6px;position:fixed;top:0;left:0;bottom:0;z-index:100}
          .logo{width:36px;height:36px;background:var(--accent);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;margin-bottom:16px}
          .nav-item{width:44px;height:44px;border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--muted);transition:all .2s;font-size:18px;position:relative;text-decoration:none}
          .nav-item:hover{background:var(--surface2);color:var(--text)}
          .nav-item.active{background:rgba(79,142,247,.15);color:var(--accent)}
          .nav-item.active::before{content:'';position:absolute;left:-1px;width:3px;height:24px;background:var(--accent);border-radius:0 4px 4px 0}
          .sidebar-bottom{margin-top:auto;display:flex;flex-direction:column;align-items:center;gap:6px}
          .s-avatar{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#4f8ef7,#6ee7b7);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;cursor:pointer}
          .main{margin-left:64px;flex:1;display:flex;flex-direction:column}
          .topbar{height:60px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 28px;gap:16px;position:sticky;top:0;z-index:50}
          .topbar h1{font-size:16px;font-weight:600;flex:1}
          .topbar-badge{background:rgba(34,197,94,.1);color:var(--live);font-size:11px;font-weight:600;padding:3px 10px;border-radius:100px;border:1px solid rgba(34,197,94,.25);display:flex;align-items:center;gap:5px}
          .topbar-badge::before{content:'';width:7px;height:7px;background:var(--live);border-radius:50%;animation:pulse 1.8s infinite}
          @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.3)}}
          .search-box{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);display:flex;align-items:center;gap:8px;padding:7px 12px;width:220px}
          .search-box input{background:none;border:none;outline:none;color:var(--text);font-family:inherit;font-size:13px;width:100%}
          .search-box input::placeholder{color:var(--muted)}
          .icon-btn{width:36px;height:36px;border-radius:var(--radius-sm);background:var(--surface2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--muted);transition:all .2s;font-size:16px}
          .icon-btn:hover{color:var(--text);border-color:rgba(255,255,255,.15)}
          .role-badge{font-size:11px;font-weight:600;padding:3px 10px;border-radius:100px;border:1px solid}
          .role-badge.manager{background:rgba(79,142,247,.1);color:var(--accent);border-color:rgba(79,142,247,.25)}
          .role-badge.salesperson{background:rgba(110,231,183,.1);color:var(--accent2);border-color:rgba(110,231,183,.25)}
          .content{padding:24px 28px;flex:1}
          .personal-banner{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px 24px;margin-bottom:24px;display:flex;align-items:center;gap:20px;flex-wrap:wrap}
          .pb-avatar{width:52px;height:52px;border-radius:50%;background:linear-gradient(135deg,#4f8ef7,#6ee7b7);display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;flex-shrink:0}
          .pb-info{flex:1}.pb-name{font-size:16px;font-weight:600}.pb-sub{font-size:12px;color:var(--muted);margin-top:3px}
          .pb-stats{display:flex;gap:28px;flex-wrap:wrap}.pb-stat{text-align:center}
          .pb-stat-val{font-size:22px;font-weight:700;font-family:'DM Mono',monospace}
          .pb-stat-lbl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-top:2px}
          .pb-actions{display:flex;gap:8px}
          .btn-primary{background:var(--accent);color:#fff;border:none;padding:8px 16px;border-radius:var(--radius-sm);font-size:12px;font-weight:600;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:6px;transition:opacity .2s}
          .btn-primary:hover{opacity:.85}
          .btn-outline{background:transparent;color:var(--text);border:1px solid var(--border);padding:8px 16px;border-radius:var(--radius-sm);font-size:12px;font-weight:600;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:6px;transition:border-color .2s}
          .btn-outline:hover{border-color:rgba(255,255,255,.2)}
          .stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px}
          .stat-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px;position:relative;overflow:hidden;transition:transform .2s,border-color .2s;cursor:default;animation:fadeUp .4s ease both}
          .stat-card:hover{transform:translateY(-2px);border-color:rgba(255,255,255,.12)}
          .stat-card::after{content:'';position:absolute;top:0;left:0;right:0;height:2px}
          .stat-card.blue::after{background:var(--accent)}.stat-card.green::after{background:var(--live)}
          .stat-card.warn::after{background:var(--warn)}.stat-card.red::after{background:var(--danger)}
          .stat-label{font-size:11px;font-weight:500;color:var(--muted);letter-spacing:.6px;text-transform:uppercase;margin-bottom:8px}
          .stat-value{font-size:32px;font-weight:700;line-height:1;font-family:'DM Mono',monospace}
          .stat-sub{font-size:12px;color:var(--muted);margin-top:6px}
          .stat-icon{position:absolute;right:20px;top:20px;font-size:28px;opacity:.12}
          .delta{display:inline-flex;align-items:center;gap:3px;font-size:11px;font-weight:600;padding:2px 6px;border-radius:4px;margin-top:6px}
          .delta.up{background:rgba(34,197,94,.1);color:var(--live)}.delta.down{background:rgba(248,113,113,.1);color:var(--danger)}
          .delta.neutral{background:rgba(107,114,128,.1);color:var(--muted)}
          .mid-grid{display:grid;grid-template-columns:1fr 340px;gap:20px;margin-bottom:24px;animation:fadeUp .4s .25s ease both}
          .map-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
          .card-header{padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
          .card-header h2{font-size:14px;font-weight:600;flex:1}
          .chip{font-size:11px;font-weight:600;padding:3px 9px;border-radius:100px}
          .chip.live{background:rgba(34,197,94,.12);color:var(--live);border:1px solid rgba(34,197,94,.25)}
          .chip.idle{background:rgba(245,158,11,.12);color:var(--warn);border:1px solid rgba(245,158,11,.25)}
          .chip.offline{background:rgba(107,114,128,.12);color:var(--muted);border:1px solid rgba(107,114,128,.25)}
          .map-container{height:340px;background:var(--surface2);position:relative;overflow:hidden}
          #liveMap{width:100%;height:100%}
          .map-overlay{position:absolute;bottom:12px;left:12px;background:rgba(13,15,20,.85);backdrop-filter:blur(8px);border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px 14px;font-size:11px;color:var(--muted);z-index:999}
          .map-overlay strong{color:var(--text);font-size:12px}
          .map-refresh-btn{position:absolute;top:12px;right:12px;background:rgba(13,15,20,.85);backdrop-filter:blur(8px);border:1px solid var(--border);border-radius:var(--radius-sm);padding:7px 12px;font-size:11px;color:var(--text);cursor:pointer;z-index:999;transition:background .2s}
          .map-refresh-btn:hover{background:rgba(79,142,247,.15)}
          .activity-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
          .activity-list{overflow-y:auto;max-height:360px}
          .activity-item{padding:12px 20px;border-bottom:1px solid var(--border);display:flex;align-items:flex-start;gap:12px;transition:background .15s}
          .activity-item:hover{background:rgba(255,255,255,.02)}.activity-item:last-child{border-bottom:none}
          .activity-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:5px}
          .activity-text{flex:1}.activity-name{font-weight:500;color:var(--text);font-size:13px}
          .activity-desc{color:var(--muted);font-size:12px;margin-top:2px}
          .activity-time{font-size:11px;color:var(--muted);font-family:'DM Mono',monospace;flex-shrink:0}
          .empty-feed{padding:32px;text-align:center;color:var(--muted);font-size:13px}
          .bottom-grid{display:grid;grid-template-columns:2fr 1fr;gap:20px;animation:fadeUp .4s .35s ease both}
          .table-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
          table{width:100%;border-collapse:collapse}
          thead th{padding:11px 16px;text-align:left;font-size:11px;font-weight:600;color:var(--muted);letter-spacing:.5px;text-transform:uppercase;border-bottom:1px solid var(--border);background:var(--surface2)}
          tbody tr{transition:background .15s}tbody tr:hover{background:rgba(255,255,255,.025)}
          tbody td{padding:12px 16px;font-size:13px;border-bottom:1px solid var(--border);vertical-align:middle}
          tbody tr:last-child td{border-bottom:none}
          .user-cell{display:flex;align-items:center;gap:10px}
          .user-avatar{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0}
          .user-name{font-weight:500}.user-team{font-size:11px;color:var(--muted)}
          .status-dot{display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:500}
          .status-dot::before{content:'';width:7px;height:7px;border-radius:50%}
          .status-dot.live::before{background:var(--live);box-shadow:0 0 6px var(--live)}
          .status-dot.idle::before{background:var(--idle)}.status-dot.offline::before{background:var(--offline)}
          .status-dot.live{color:var(--live)}.status-dot.idle{color:var(--idle)}.status-dot.offline{color:var(--muted)}
          .state-badge{display:inline-block;font-size:11px;font-weight:600;padding:3px 8px;border-radius:4px}
          .state-accepted{background:rgba(79,142,247,.12);color:var(--accent)}
          .state-planned{background:rgba(245,158,11,.12);color:var(--warn)}
          .state-done{background:rgba(110,231,183,.12);color:var(--accent2)}
          .state-rejected{background:rgba(248,113,113,.12);color:var(--danger)}
          .state-visited{background:rgba(167,139,250,.12);color:#a78bfa}
          .progress-bar{width:80px;height:6px;background:var(--surface2);border-radius:3px;overflow:hidden}
          .progress-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--accent),var(--accent2));transition:width .6s ease}
          .progress-fill.warn{background:linear-gradient(90deg,var(--warn),#fbbf24)}
          .progress-fill.danger{background:linear-gradient(90deg,var(--danger),#f87171)}
          .mono{font-family:'DM Mono',monospace}
          .kpi-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
          .donut-wrap{padding:20px;display:flex;flex-direction:column;align-items:center}
          .donut-svg{width:140px;height:140px}
          .kpi-legend{width:100%;margin-top:16px}
          .kpi-legend-item{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px}
          .kpi-legend-item:last-child{border-bottom:none}
          .legend-dot{width:10px;height:10px;border-radius:50%;display:inline-block;margin-right:8px}
          .legend-left{display:flex;align-items:center;color:var(--muted)}.legend-val{font-weight:600;font-family:'DM Mono',monospace}
          .empty-table{padding:40px;text-align:center;color:var(--muted);font-size:13px}
          @keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
          .stat-card:nth-child(1){animation-delay:.05s}.stat-card:nth-child(2){animation-delay:.10s}
          .stat-card:nth-child(3){animation-delay:.15s}.stat-card:nth-child(4){animation-delay:.20s}
          [data-tip]{position:relative}
          [data-tip]:hover::after{content:attr(data-tip);position:absolute;bottom:calc(100% + 6px);left:50%;transform:translateX(-50%);background:#1e2230;border:1px solid var(--border);color:var(--text);font-size:11px;padding:4px 8px;border-radius:4px;white-space:nowrap;z-index:999}
          @media(max-width:1100px){.stat-row{grid-template-columns:repeat(2,1fr)}.mid-grid,.bottom-grid{grid-template-columns:1fr}}
        </style>
      </t>

      <div class="layout">
        <!-- Sidebar -->
        <nav class="sidebar">
          <div class="logo">&#128205;</div>
          <div class="nav-item active" data-tip="Dashboard">&#128506;</div>
          <t t-if="is_manager">
            <div class="nav-item" data-tip="Salespersons">&#128101;</div>
            <div class="nav-item" data-tip="Visit Plans">&#128203;</div>
            <div class="nav-item" data-tip="Check-ins">&#9989;</div>
            <div class="nav-item" data-tip="KPIs">&#128202;</div>
            <div class="nav-item" data-tip="Reports">&#128196;</div>
          </t>
          <t t-else="">
            <a class="nav-item" href="/salesperson_tracking/live" data-tip="Live Tracking">&#128247;</a>
            <div class="nav-item" data-tip="My Check-ins">&#9989;</div>
            <div class="nav-item" data-tip="My KPIs">&#128202;</div>
          </t>
          <div class="sidebar-bottom">
            <div class="nav-item" data-tip="Settings">&#9881;</div>
            <div class="s-avatar" data-tip="Me"><t t-esc="(user.name or 'U')[:2].upper()"/></div>
          </div>
        </nav>

        <!-- Main -->
        <div class="main">
          <!-- Topbar -->
          <header class="topbar">
            <h1>
              <t t-if="is_manager">Live Tracking Dashboard</t>
              <t t-else="">My Field Dashboard</t>
            </h1>
            <div class="topbar-badge" id="live-badge"><t t-esc="live_count"/> Active Now</div>
            <t t-if="is_manager">
              <div class="search-box">
                <span>&#128269;</span>
                <input type="text" id="searchInput" placeholder="Search salesperson&#8230;"/>
              </div>
            </t>
            <span t-attf-class="role-badge #{'manager' if is_manager else 'salesperson'}">
              <t t-if="is_manager">&#128081; Manager</t>
              <t t-else="">&#128100; Salesperson</t>
            </span>
            <div class="icon-btn" id="refreshBtn" data-tip="Refresh">&#128260;</div>
          </header>

          <div class="content">

            <!-- Personal banner (salesperson only) -->
            <t t-if="not is_manager">
              <div class="personal-banner">
                <div class="pb-avatar"><t t-esc="(user.name or 'U')[:2].upper()"/></div>
                <div class="pb-info">
                  <div class="pb-name"><t t-esc="user.name"/></div>
                  <div class="pb-sub">
                    <t t-if="my_status == 'live'">&#128994; Live · </t>
                    <t t-elif="my_status == 'idle'">&#128993; Idle · </t>
                    <t t-else="">&#9899; Offline · </t>
                    <t t-esc="my_location"/>
                  </div>
                </div>
                <div class="pb-stats">
                  <div class="pb-stat">
                    <div class="pb-stat-val" style="color:var(--accent2)"><t t-esc="my_dist"/> km</div>
                    <div class="pb-stat-lbl">Distance Today</div>
                  </div>
                  <div class="pb-stat">
                    <div class="pb-stat-val" style="color:var(--accent)"><t t-esc="my_covered"/>/<t t-esc="my_total"/></div>
                    <div class="pb-stat-lbl">Visits Covered</div>
                  </div>
                  <div class="pb-stat">
                    <div class="pb-stat-val" style="color:var(--live)"><t t-esc="my_checkins_today"/></div>
                    <div class="pb-stat-lbl">Check-ins Today</div>
                  </div>
                </div>
                <div class="pb-actions">
                  <a href="/salesperson_tracking/live" class="btn-primary">&#128247; Start Tracking</a>
                  <a href="/web#model=salesperson.tracker&amp;view_type=list" class="btn-outline">&#128196; My Records</a>
                </div>
              </div>
            </t>

            <!-- Stat cards -->
            <div class="stat-row">
              <t t-if="is_manager">
                <div class="stat-card blue">
                  <div class="stat-label">Total Field Reps</div>
                  <div class="stat-value"><t t-esc="total_reps"/></div>
                  <div class="stat-icon">&#128100;</div>
                  <div class="delta neutral">&#128101; Tracked</div>
                </div>
                <div class="stat-card green">
                  <div class="stat-label">Live Right Now</div>
                  <div class="stat-value" style="color:var(--live)"><t t-esc="live_count"/></div>
                  <div class="stat-icon">&#128994;</div>
                  <div class="stat-sub"><t t-esc="idle_count"/> idle · <t t-esc="offline_count"/> offline</div>
                </div>
                <div class="stat-card warn">
                  <div class="stat-label">Today's Visits Planned</div>
                  <div class="stat-value" style="color:var(--warn)"><t t-esc="total_planned"/></div>
                  <div class="stat-icon">&#128203;</div>
                  <div class="delta up">&#9650; <t t-esc="total_covered"/> covered</div>
                </div>
                <div class="stat-card red">
                  <div class="stat-label">Route Deviation Alerts</div>
                  <div class="stat-value" style="color:var(--danger)"><t t-esc="deviation_alerts"/></div>
                  <div class="stat-icon">&#9888;</div>
                  <div class="delta down">&#9660; Needs review</div>
                </div>
              </t>
              <t t-else="">
                <div class="stat-card green">
                  <div class="stat-label">My Status</div>
                  <div class="stat-value" style="font-size:18px;padding-top:6px;">
                    <t t-if="my_status == 'live'" t-attf-style="color:var(--live)">&#128247; Live</t>
                    <t t-elif="my_status == 'idle'" t-attf-style="color:var(--warn)">&#128336; Idle</t>
                    <t t-else="" t-attf-style="color:var(--muted)">&#128900; Offline</t>
                  </div>
                  <div class="stat-icon">&#128247;</div>
                  <div class="stat-sub"><t t-esc="my_location"/></div>
                </div>
                <div class="stat-card blue">
                  <div class="stat-label">Distance Today</div>
                  <div class="stat-value"><t t-esc="my_dist"/></div>
                  <div class="stat-icon">&#128346;</div>
                  <div class="stat-sub">km travelled</div>
                </div>
                <div class="stat-card warn">
                  <div class="stat-label">Visits Covered</div>
                  <div class="stat-value" style="color:var(--warn)"><t t-esc="my_covered"/>/<t t-esc="my_total"/></div>
                  <div class="stat-icon">&#128203;</div>
                  <div class="stat-sub">today's plan</div>
                </div>
                <div class="stat-card blue">
                  <div class="stat-label">Check-ins Today</div>
                  <div class="stat-value" style="color:var(--accent2)"><t t-esc="my_checkins_today"/></div>
                  <div class="stat-icon">&#9989;</div>
                  <div class="stat-sub">visits recorded</div>
                </div>
              </t>
            </div>

            <!-- Mid grid -->
            <div class="mid-grid">
              <!-- Live Map -->
              <div class="map-card">
                <div class="card-header">
                  <h2>Live Field Map</h2>
                  <span class="chip live" id="mapLiveChip"><t t-esc="live_count"/> Live</span>
                  <span class="chip idle" id="mapIdleChip"><t t-esc="idle_count"/> Idle</span>
                  <t t-if="is_manager">
                    <span class="chip offline" id="mapOfflineChip"><t t-esc="offline_count"/> Offline</span>
                  </t>
                </div>
                <div class="map-container">
                  <div id="liveMap"></div>
                  <button class="map-refresh-btn" id="mapRefreshBtn">&#128260; Refresh</button>
                  <div class="map-overlay">
                    <strong>Field Map</strong><br/>
                    Last refresh: <span id="mapLastRefresh">just now</span>
                  </div>
                </div>
              </div>
              <!-- Activity Feed -->
              <div class="activity-card">
                <div class="card-header">
                  <h2>Live Activity</h2>
                  <span style="font-size:11px;color:var(--muted)"><t t-esc="today"/></span>
                </div>
                <div class="activity-list">
                  <t t-if="activity_feed">
                    <t t-foreach="activity_feed" t-as="act">
                      <div class="activity-item">
                        <div class="activity-dot" t-attf-style="background:#{act['dot_color']}"></div>
                        <div class="activity-text">
                          <div class="activity-name"><t t-esc="act['name']"/></div>
                          <div class="activity-desc"><t t-esc="act['desc']"/></div>
                        </div>
                        <div class="activity-time"><t t-esc="act['time']"/></div>
                      </div>
                    </t>
                  </t>
                  <t t-else="">
                    <div class="empty-feed">No activity recorded today yet.</div>
                  </t>
                </div>
              </div>
            </div>

            <!-- Bottom grid -->
            <div class="bottom-grid">
              <!-- Table -->
              <div class="table-card">
                <div class="card-header">
                  <h2>
                    <t t-if="is_manager">Field Representatives</t>
                    <t t-else="">My Visit Summary</t>
                  </h2>
                  <span style="font-size:11px;color:var(--muted)"><t t-esc="len(rows)"/> rep(s)</span>
                </div>
                <t t-if="rows">
                  <table>
                    <thead>
                      <tr>
                        <th>Representative</th>
                        <th>Status</th>
                        <th>Stage</th>
                        <th>Coverage</th>
                        <th>Distance</th>
                        <th>Last Seen</th>
                      </tr>
                    </thead>
                    <tbody id="repTableBody">
                      <t t-foreach="rows" t-as="row">
                        <tr class="rep-row" t-att-data-name="row['name'].lower()">
                          <td>
                            <div class="user-cell">
                              <div class="user-avatar" t-attf-style="background:#{row['gradient']}">
                                <t t-esc="row['initials']"/>
                              </div>
                              <div>
                                <div class="user-name"><t t-esc="row['name']"/></div>
                                <div class="user-team"><t t-esc="row['team']"/></div>
                              </div>
                            </div>
                          </td>
                          <td>
                            <span t-attf-class="status-dot #{row['status']}">
                              <t t-esc="row['status'].title()"/>
                            </span>
                          </td>
                          <td>
                            <span t-attf-class="state-badge state-#{row['state']}">
                              <t t-esc="row['state'].title()"/>
                            </span>
                          </td>
                          <td>
                            <div style="display:flex;align-items:center;gap:8px;">
                              <div class="progress-bar">
                                <div t-attf-class="progress-fill #{'danger' if row['pct'] &lt; 30 else 'warn' if row['pct'] &lt; 60 else ''}"
                                     t-attf-style="width:#{row['pct']}%"></div>
                              </div>
                              <span class="mono" style="font-size:11px;">
                                <t t-esc="row['covered']"/>/<t t-esc="row['total']"/>
                              </span>
                            </div>
                          </td>
                          <td class="mono"><t t-esc="row['distance']"/></td>
                          <td class="mono" style="color:var(--muted)"><t t-esc="row['last_seen']"/></td>
                        </tr>
                      </t>
                    </tbody>
                  </table>
                </t>
                <t t-else="">
                  <div class="empty-table">No field representatives found for today.</div>
                </t>
              </div>

              <!-- KPI Donut -->
              <div class="kpi-card">
                <div class="card-header">
                  <h2>Today's KPI</h2>
                  <span style="font-size:11px;color:var(--muted)"><t t-esc="today"/></span>
                </div>
                <div class="donut-wrap">
                  <t t-if="is_manager">
                    <svg class="donut-svg" viewBox="0 0 140 140" xmlns="http://www.w3.org/2000/svg">
                      <defs>
                        <linearGradient id="kpiGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                          <stop offset="0%" stop-color="#4f8ef7"/>
                          <stop offset="100%" stop-color="#6ee7b7"/>
                        </linearGradient>
                      </defs>
                      <circle cx="70" cy="70" r="52" fill="none" stroke="rgba(255,255,255,.06)" stroke-width="18"/>
                      <t t-if="total_planned &gt; 0">
                        <circle cx="70" cy="70" r="52" fill="none" stroke="url(#kpiGrad)" stroke-width="18"
                          t-attf-stroke-dasharray="#{round(kpi_covered * 326.7 / total_planned, 1)} 326.7"
                          stroke-dashoffset="81.7" stroke-linecap="round" transform="rotate(-90 70 70)"/>
                      </t>
                      <text x="70" y="63" text-anchor="middle" fill="white" font-size="22" font-weight="700" font-family="DM Mono">
                        <t t-esc="kpi_pct"/>%
                      </text>
                      <text x="70" y="80" text-anchor="middle" fill="#6b7280" font-size="9" font-family="DM Sans">completion</text>
                    </svg>
                    <div class="kpi-legend">
                      <div class="kpi-legend-item">
                        <div class="legend-left"><span class="legend-dot" style="background:#4f8ef7"></span>Visits Covered</div>
                        <div class="legend-val" style="color:#4f8ef7"><t t-esc="kpi_covered"/></div>
                      </div>
                      <div class="kpi-legend-item">
                        <div class="legend-left"><span class="legend-dot" style="background:#f59e0b"></span>Remaining</div>
                        <div class="legend-val" style="color:#f59e0b"><t t-esc="kpi_in_progress"/></div>
                      </div>
                      <div class="kpi-legend-item">
                        <div class="legend-left"><span class="legend-dot" style="background:#6b7280"></span>Total Planned</div>
                        <div class="legend-val"><t t-esc="total_planned"/></div>
                      </div>
                      <div class="kpi-legend-item">
                        <div class="legend-left"><span class="legend-dot" style="background:#22c55e"></span>Live Reps</div>
                        <div class="legend-val" style="color:#22c55e"><t t-esc="live_count"/></div>
                      </div>
                    </div>
                  </t>
                  <t t-else="">
                    <svg class="donut-svg" viewBox="0 0 140 140" xmlns="http://www.w3.org/2000/svg">
                      <defs>
                        <linearGradient id="myGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                          <stop offset="0%" stop-color="#4f8ef7"/>
                          <stop offset="100%" stop-color="#6ee7b7"/>
                        </linearGradient>
                      </defs>
                      <circle cx="70" cy="70" r="52" fill="none" stroke="rgba(255,255,255,.06)" stroke-width="18"/>
                      <t t-if="my_total &gt; 0">
                        <circle cx="70" cy="70" r="52" fill="none" stroke="url(#myGrad)" stroke-width="18"
                          t-attf-stroke-dasharray="#{round(my_covered * 326.7 / my_total, 1)} 326.7"
                          stroke-dashoffset="81.7" stroke-linecap="round" transform="rotate(-90 70 70)"/>
                      </t>
                      <text x="70" y="63" text-anchor="middle" fill="white" font-size="22" font-weight="700" font-family="DM Mono">
                        <t t-if="my_total &gt; 0"><t t-esc="round(my_covered * 100 / my_total)"/>%</t>
                        <t t-else="">&#8212;</t>
                      </text>
                      <text x="70" y="80" text-anchor="middle" fill="#6b7280" font-size="9" font-family="DM Sans">my completion</text>
                    </svg>
                    <div class="kpi-legend">
                      <div class="kpi-legend-item">
                        <div class="legend-left"><span class="legend-dot" style="background:#4f8ef7"></span>Covered</div>
                        <div class="legend-val" style="color:#4f8ef7"><t t-esc="my_covered"/></div>
                      </div>
                      <div class="kpi-legend-item">
                        <div class="legend-left"><span class="legend-dot" style="background:#f59e0b"></span>Remaining</div>
                        <div class="legend-val" style="color:#f59e0b"><t t-esc="my_total - my_covered"/></div>
                      </div>
                      <div class="kpi-legend-item">
                        <div class="legend-left"><span class="legend-dot" style="background:#6b7280"></span>Total Planned</div>
                        <div class="legend-val"><t t-esc="my_total"/></div>
                      </div>
                      <div class="kpi-legend-item">
                        <div class="legend-left"><span class="legend-dot" style="background:#22c55e"></span>Check-ins</div>
                        <div class="legend-val" style="color:#22c55e"><t t-esc="my_checkins_today"/></div>
                      </div>
                    </div>
                  </t>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>

      <!-- Leaflet JS -->
      <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

      <!-- Dashboard logic — wrapped in CDATA so lxml does not parse JS as XML -->
      <script>
        //<![CDATA[
        var TRACKER_DATA = <t t-raw="json.dumps(rows)"/>;
        var IS_MANAGER   = <t t-raw="'true' if is_manager else 'false'"/>;

        var map = L.map('liveMap', {zoomControl: true, attributionControl: false});
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {maxZoom: 19}).addTo(map);

        var mapMarkers = {};

        function statusColor(s) {
          return s === 'live' ? '#22c55e' : s === 'idle' ? '#f59e0b' : '#4b5563';
        }

        function makeIcon(status, initials) {
          var col   = statusColor(status);
          var pulse = '';
          if (status === 'live') {
            pulse = '<circle cx="18" cy="18" r="14" fill="none" stroke="' + col + '" stroke-width="1.5" opacity="0.5">'
              + '<animate attributeName="r" values="11;18;11" dur="2s" repeatCount="indefinite"/>'
              + '<animate attributeName="opacity" values="0.5;0;0.5" dur="2s" repeatCount="indefinite"/>'
              + '</circle>';
          }
          var svg = '<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 36 36">'
            + '<circle cx="18" cy="18" r="16" fill="' + col + '" opacity=".2"/>'
            + '<circle cx="18" cy="18" r="11" fill="' + col + '"/>'
            + '<text x="18" y="22" text-anchor="middle" fill="white" font-size="8" font-family="DM Sans" font-weight="700">' + initials + '</text>'
            + pulse
            + '</svg>';
          return L.divIcon({html: svg, className: '', iconSize: [36, 36], iconAnchor: [18, 18], popupAnchor: [0, -20]});
        }

        function buildPopup(row) {
          var col = statusColor(row.status);
          return '<div style="font-family:DM Sans,sans-serif;min-width:160px;padding:4px">'
            + '<b style="font-size:13px">' + row.name + '</b><br/>'
            + '<span style="font-size:11px;color:#6b7280">&#128205; ' + (row.location || 'Unknown') + '</span><br/>'
            + '<span style="font-size:11px">Status: <b style="color:' + col + '">' + row.status.toUpperCase() + '</b></span><br/>'
            + '<span style="font-size:11px">Visits: ' + row.covered + '/' + row.total + '</span><br/>'
            + '<span style="font-size:11px">Distance: ' + row.distance + '</span>'
            + '</div>';
        }

        function loadMarkers(data) {
          Object.values(mapMarkers).forEach(function(m) { map.removeLayer(m); });
          mapMarkers = {};
          var bounds = [];
          data.forEach(function(row) {
            if (!row.lat || !row.lng) return;
            var m = L.marker([row.lat, row.lng], {icon: makeIcon(row.status, row.initials || '?')});
            m.bindPopup(buildPopup(row));
            m.addTo(map);
            mapMarkers[row.id] = m;
            bounds.push([row.lat, row.lng]);
          });
          if (bounds.length) {
            map.fitBounds(bounds, {padding: [40, 40], maxZoom: 14});
          } else {
            map.setView([23.8103, 90.4125], 11);
          }
        }

        loadMarkers(TRACKER_DATA);

        var refreshSecs    = 0;
        var lastRefreshEl  = document.getElementById('mapLastRefresh');
        var liveBadge      = document.getElementById('live-badge');
        var liveChip       = document.getElementById('mapLiveChip');
        var idleChip       = document.getElementById('mapIdleChip');
        var offlineChip    = document.getElementById('mapOfflineChip');

        function refreshDashboard() {
          refreshSecs = 0;
          fetch('/salesperson/dashboard/data')
            .then(function(r) { return r.json(); })
            .then(function(d) {
              if (!d.ok) return;
              loadMarkers(d.trackers);
              if (liveBadge)    liveBadge.textContent    = d.live_count + ' Active Now';
              var idle    = d.trackers.filter(function(t) { return t.status === 'idle';    }).length;
              var offline = d.trackers.filter(function(t) { return t.status === 'offline'; }).length;
              if (liveChip)    liveChip.textContent    = d.live_count + ' Live';
              if (idleChip)    idleChip.textContent    = idle + ' Idle';
              if (offlineChip) offlineChip.textContent = offline + ' Offline';
              if (lastRefreshEl) lastRefreshEl.textContent = 'just now';
            })
            .catch(function(e) { console.warn('refresh error', e); });
        }

        document.getElementById('refreshBtn').addEventListener('click', refreshDashboard);
        document.getElementById('mapRefreshBtn').addEventListener('click', refreshDashboard);

        setInterval(refreshDashboard, 30000);
        setInterval(function() {
          refreshSecs++;
          if (lastRefreshEl) {
            lastRefreshEl.textContent = refreshSecs < 60
              ? refreshSecs + 's ago'
              : Math.floor(refreshSecs / 60) + 'min ago';
          }
        }, 1000);

        window.addEventListener('focus', function() { refreshDashboard(); });

        // Nav highlight
        document.querySelectorAll('.nav-item').forEach(function(el) {
          el.addEventListener('click', function() {
            document.querySelectorAll('.nav-item').forEach(function(n) { n.classList.remove('active'); });
            el.classList.add('active');
          });
        });

        // Search filter
        var searchInput = document.getElementById('searchInput');
        if (searchInput) {
          searchInput.addEventListener('input', function() {
            var q = this.value.toLowerCase().trim();
            document.querySelectorAll('.rep-row').forEach(function(row) {
              var nm = row.getAttribute('data-name') || '';
              row.style.display = (!q || nm.indexOf(q) !== -1) ? '' : 'none';
            });
          });
        }
        //]]>
      </script>

    </t>
  </template>
</odoo>