<odoo>

    <!-- LIST VIEW -->
    <record id="view_sales_person_dashboard_list" model="ir.ui.view">
        <field name="name">sales.person.dashboard.list</field>
        <field name="model">sales.person.dashboard</field>
        <field name="arch" type="xml">
            <list string="Salesperson Dashboards"
                  decoration-info="state == 'planned'"
                  decoration-primary="state == 'visited'"
                  decoration-success="state == 'accepted'"
                  decoration-danger="state == 'rejected'"
                  multi_edit="1">
                <field name="name" string="Reference"/>
                <field name="sales_person" string="Sales Person"/>
                <field name="manager" string="Manager"/>
                <field name="partner_ids" string="Partners" widget="many2many_tags"/>
                <field name="state" string="Stage"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_sales_person_dashboard_form" model="ir.ui.view">
        <field name="name">sales.person.dashboard.form</field>
        <field name="model">sales.person.dashboard</field>
        <field name="arch" type="xml">
            <form string="Salesperson Dashboard">
                <header>
                    <button name="action_set_visited"
                            string="Mark as Visited"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'planned'"/>

                    <button name="action_set_accepted"
                            string="Accept"
                            type="object"
                            class="btn-success"
                            invisible="state != 'visited'"/>

                    <button name="action_set_rejected"
                            string="Reject"
                            type="object"
                            class="btn-danger"
                            invisible="state != 'visited'"/>

                    <button name="action_set_planned"
                            string="Reset to Planned"
                            type="object"
                            invisible="state == 'planned'"/>

                    <field name="state" widget="statusbar"
                        statusbar_visible="planned,visited,accepted,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="General Information">
                            <field name="sales_person" string="Sales Person"/>
                            <field name="manager" string="Manager"/>
                        </group>
                        <group string="Partners">
                            <field name="partner_ids"
                                   widget="many2many_tags"
                                   nolabel="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Visit Lines">
                            <field name="line_ids">
                                <list editable="bottom"
                                      decoration-success="state == 'visited'"
                                      decoration-danger="state == 'cancelled'"
                                      decoration-info="state == 'planned'">
                                    <field name="partner_id" string="Partner"/>
                                    <field name="visit_date" string="Visit Date"/>
                                    <field name="from_location" string="From"/>
                                    <field name="to_location" string="To"/>
                                    <field name="total_cost" string="Total Cost"/>
                                    <field name="state" string="Status"/>
                                    <field name="notes" string="Notes" optional="show"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="view_sales_person_dashboard_kanban" model="ir.ui.view">
        <field name="name">sales.person.dashboard.kanban</field>
        <field name="model">sales.person.dashboard</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state"
                    class="o_kanban_small_column"
                    sample="1"
                    quick_create="0">

                <field name="name"/>
                <field name="state"/>
                <field name="sales_person"/>
                <field name="manager"/>
                <field name="partner_ids"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click p-3">

                            <!-- Header: Reference + State Badge -->
                            <div class="d-flex align-items-start justify-content-between mb-3">
                                <strong class="o_kanban_record_title fs-6 text-truncate me-2">
                                    <field name="name"/>
                                </strong>

                                <t t-if="record.state.raw_value == 'planned'">
                                    <span class="badge rounded-pill text-bg-info px-2 py-1">
                                        <i class="fa fa-clock-o me-1"/> Planned
                                    </span>
                                </t>
                                <t t-if="record.state.raw_value == 'visited'">
                                    <span class="badge rounded-pill text-bg-primary px-2 py-1">
                                        <i class="fa fa-map-marker me-1"/> Visited
                                    </span>
                                </t>
                                <t t-if="record.state.raw_value == 'accepted'">
                                    <span class="badge rounded-pill text-bg-success px-2 py-1">
                                        <i class="fa fa-check me-1"/> Accepted
                                    </span>
                                </t>
                                <t t-if="record.state.raw_value == 'rejected'">
                                    <span class="badge rounded-pill text-bg-danger px-2 py-1">
                                        <i class="fa fa-times me-1"/> Rejected
                                    </span>
                                </t>

                            </div>

                            <!-- Body -->
                            <div class="o_kanban_record_body">
                                <div class="mb-2 d-flex align-items-center gap-2">
                                    <i class="fa fa-user text-muted"/>
                                    <span class="text-muted small">Sales Person:</span>
                                    <strong class="small">
                                        <field name="sales_person"/>
                                    </strong>
                                </div>
                                <div class="mb-2 d-flex align-items-center gap-2">
                                    <i class="fa fa-briefcase text-muted"/>
                                    <span class="text-muted small">Manager:</span>
                                    <span class="small">
                                        <field name="manager"/>
                                    </span>
                                </div>
                            </div>

                            <!-- Footer: Partners -->
                            <div class="o_kanban_record_bottom border-top pt-2 mt-2">
                                <div class="oe_kanban_bottom_left">
                                    <field name="partner_ids" widget="many2many_tags"/>
                                </div>
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_sales_person_dashboard" model="ir.actions.act_window">
        <field name="name">Salesperson Dashboards</field>
        <field name="res_model">sales.person.dashboard</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_sales_person_dashboard_kanban')}),
            (0, 0, {'view_mode': 'list',   'view_id': ref('view_sales_person_dashboard_list')}),
            (0, 0, {'view_mode': 'form',   'view_id': ref('view_sales_person_dashboard_form')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Salesperson Dashboard!
            </p>
        </field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_salesperson_tracking_root"
              name="Salesperson Dashboard"
              sequence="50"/>

    <menuitem id="menu_salesperson_tracking_main"
              name="Salesperson Dashboard"
              parent="menu_salesperson_tracking_root"
              sequence="10"/>

    <menuitem id="menu_sales_person_dashboard"
              name="Dashboards"
              parent="menu_salesperson_tracking_main"
              action="action_sales_person_dashboard"
              sequence="10"/>

</odoo>